#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

#define DEFAULT 0
#define LWR 1

/ {
    combos {
        compatible = "zmk,combos";

        /*
         * Emergency bootloader combo.
         * Kept from your original keymap.
         */
        BootL {
            bindings = <&bootloader>;
            key-positions = <16 15 24 36>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
/* LEFT MAIN ─────────────────────────────────────────────── RIGHT MAIN ────────────────────────────────────────────── */
/* esc      1       2       3       4       5               6       7       8       9       0       \ |              */
   &kp ESC   &kp N1  &kp N2  &kp N3  &kp N4  &kp N5          &kp N6  &kp N7  &kp N8  &kp N9  &kp N0  &kp BACKSLASH

/* tab      Q       W       E       R       T               Y       U       I       O       P       [ {              */
   &kp TAB   &kp Q   &kp W   &kp E   &kp R   &kp T           &kp Y   &kp U   &kp I   &kp O   &kp P   &kp LEFT_BRACKET

/* ctrl     A       S       D       F       G               H       J       K       L       ; :     ' "              */
   &kp LCTRL &kp A   &kp S   &kp D   &kp F   &kp G           &kp H   &kp J   &kp K   &kp L   &kp SEMI &kp SQT

/* shift    Z       X       C       V       B               N       M       , <     . >     / ?     ] }              */
   &kp LSHFT &kp Z   &kp X   &kp C   &kp V   &kp B           &kp N   &kp M   &kp COMMA &kp DOT &kp SLASH &kp RIGHT_BRACKET

/*                         home    end                                      - _     = +                              */
                              &kp HOME &kp END                              &kp MINUS &kp EQUAL

/*                                 space   option                  return   delete/backspace                         */
                                      &kp SPACE &kp LALT           &kp RET  &kp BACKSPACE

/*                                          command Lower          up       down                                     */
                                                &kp LCMD &mo LWR   &kp UP_ARROW &kp DOWN_ARROW

/*                                          pageup  pagedown       left     right                                    */
                                                &kp PAGE_UP &kp PAGE_DOWN &kp LEFT_ARROW &kp RIGHT_ARROW
            >;
        };

        lower_layer {
            bindings = <
/* LOWER: F-KEYS ─────────────────────────────────────────── */
/* F1          F2          F3          F4          F5          F6              F7          F8          F9          F10         F11         F12 */
   &kp F1      &kp F2      &kp F3      &kp F4      &kp F5      &kp F6          &kp F7      &kp F8      &kp F9      &kp F10     &kp F11     &kp F12

/* LOWER: BT SELECT + NAV ────────────────────────────────── */
/* ` ~         BT0         BT1         BT2         BT3         BT4             —           home        up          end         pgup        —   */
   &kp GRAVE   &bt BT_SEL 0 &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_SEL 3 &bt BT_SEL 4 &trans      &kp HOME    &kp UP_ARROW &kp END    &kp PAGE_UP &trans

/* LOWER: BT DISCONNECT + NAV ────────────────────────────── */
/* caps        dis0        dis1        dis2        dis3        dis4            —           left        down        right       pgdn        —   */
   &kp CAPS    &bt BT_DISC 0 &bt BT_DISC 1 &bt BT_DISC 2 &bt BT_DISC 3 &bt BT_DISC 4 &trans &kp LEFT_ARROW &kp DOWN_ARROW &kp RIGHT_ARROW &kp PAGE_DOWN &trans

/* LOWER: BT CLEAR + MEDIA + MAC TEXT NAV ────────────────── */
/* boot        clear       clear-all   prev        play/pause  next            —           word←       word→       line←       line→       fwd-del */
   &bootloader &bt BT_CLR  &bt BT_CLR_ALL &kp C_PREV &kp C_PLAY_PAUSE &kp C_NEXT &trans     &kp LA(LEFT_ARROW) &kp LA(RIGHT_ARROW) &kp LG(LEFT_ARROW) &kp LG(RIGHT_ARROW) &kp DEL

/*                         bright-     bright+                                  vol-        vol+                     */
                              &kp C_BRI_DN &kp C_BRI_UP                         &kp C_VOL_DN &kp C_VOL_UP

/*                                   transparent transparent          transparent forward-delete                      */
                                      &trans      &trans                         &trans       &kp DEL

/*                                             transparent transparent transparent transparent                        */
                                                   &trans &trans                 &trans       &trans

/*                                             transparent transparent transparent transparent                        */
                                                   &trans &trans                 &trans       &trans
            >;
        };
    };
};
